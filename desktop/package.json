{
  "name": "sourcehero-ai-desktop",
  "version": "0.5.0",
  "private": true,
  "description": "Electron desktop shell for SourceHero AI.",
  "main": "main.js",
  "scripts": {
    "dev": "node scripts/ensure-electron.js && electron .",
    "start": "node scripts/ensure-electron.js && electron .",
    "ensure-electron": "node scripts/ensure-electron.js",
    "setup:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\setup-windows.ps1",
    "setup:macos": "bash ../scripts/setup-macos.sh",
    "smoke": "node scripts/smoke.js",
    "build:runtime:mac": "bash ../scripts/build-runtime.sh",
    "build:runtime:win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\build-runtime.ps1",
    "dist:mac": "electron-builder --mac --config electron-builder.yml",
    "dist:win": "electron-builder --win --config electron-builder.yml"
  },
  "devDependencies": {
    "@electron/get": "^4.0.1",
    "extract-zip": "^2.0.1",
    "electron": "^42.2.0",
    "electron-builder": "^24.13.3"
  }
}
