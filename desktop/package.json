{
  "name": "sourcepilot-ai-desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Electron desktop shell for SourcePilot AI.",
  "main": "main.js",
  "scripts": {
    "dev": "node scripts/ensure-electron.js && electron .",
