# SourceHero AI configuration.
# Most users do not need any of these. Defaults use a per-user platform data dir,
# and the OpenAI key can be set inside the app under the Settings tab.
# Override SOURCEHERO_DATA_DIR for a portable / project-local install.

# SOURCEHERO_DATA_DIR=/path/to/data
# SOURCEHERO_DATABASE_URL=sqlite:///./data/sourcehero.db
# SOURCEHERO_RAW_DIR=./data/raw
# SOURCEHERO_VECTOR_DIR=./data/vector_index
SOURCEHERO_HTTP_TIMEOUT=20
SOURCEHERO_API_PORT=8000
SOURCEHERO_DASHBOARD_PORT=8501

# Optional: configure OpenAI synthesis from outside the app.
# Leave blank and use the in-app Settings tab instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
